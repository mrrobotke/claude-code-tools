{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(.*)",
      "Grep(.*)",
      "Glob(.*)",
      "Write(.*)",
      "Edit(.*)",
      "MultiEdit(.*)",
      "TodoWrite(.*)",
      "Task(.*)",
      "Bash(.:*)",
      "SlashCommand(.*)",
      "NotebookRead(.*)",
      "NotebookEdit(.*)"
    ],
    "deny": [
      "Bash\\(.*rm(\\s|-).*\\)",
      "Bash\\(.*shutdown.*\\)",
      "Bash\\(.*reboot.*\\)"
    ],
    "requireApproval": [
      "Bash(git commit*)",
      "Bash(gh pr create*)",
      "Bash(git checkout -b*)",
      "Bash(git merge*)",
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": []
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/comment-guidelines-context.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/atomic-context-injector.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-security-enforcer.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-commit-validator.sh"
          }
        ]
      },
      {
        "matcher": "Bash\\(git commit.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-coverage.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-file-naming.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/atomic-structure-validator.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/atomic-boundary-checker.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-typescript.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/atomic-test-validator.sh"
          }
        ]
      }
    ],
    "Stop": [],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hookslog-session-metrics.py"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754067067452
  }
}
